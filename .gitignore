# ── Секреты — никогда не коммитить ──────────────────────────────────────────
.env

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env.local

# ── PyCharm ──────────────────────────────────────────────────────────────────
.idea/

# ── Docker ───────────────────────────────────────────────────────────────────
# Docker volumes управляются Docker — не нужны в репозитории

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Данные и веса моделей ─────────────────────────────────────────────────────
*.pth
*.onnx
*.las
*.laz
*.ply
*.pcd
workers/*/models/weights/

# ── User examples output ──────────────────────────────────────────────────────
examples/out/
examples/model_outputs/

# ── External model repositories (downloaded from GitHub) ─────────────────────
external_models/

# ── Local benchmark datasets (generated/downloaded, not versioned) ───────────
data/raw_benchmark/
data/benchmark_inputs/
data/benchmark_manifests/

# ── User-installed model folders (keep templates out of git by default) ──────
workers/segmentation/**
workers/completion/**
workers/meshing/**
workers/preprocessing/**
workers/training/**

# Keep onboarding/testing scaffolds tracked
!workers/testing/
!workers/testing/**
!workers/base/
!workers/base/**
!workers/segmentation/
!workers/segmentation/fake_segmentation/
!workers/segmentation/fake_segmentation/**
!workers/meshing/
!workers/meshing/shape_as_points/
!workers/meshing/shape_as_points/**

# Re-ignore caches inside whitelisted scaffolds
workers/testing/**/__pycache__/
workers/base/**/__pycache__/
workers/segmentation/fake_segmentation/**/__pycache__/
workers/meshing/shape_as_points/**/__pycache__/
workers/testing/**/*.py[cod]
workers/base/**/*.py[cod]
workers/segmentation/fake_segmentation/**/*.py[cod]
workers/meshing/shape_as_points/**/*.py[cod]